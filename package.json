{
  "name": "heapkit",
  "version": "0.1.0",
  "description": "Zero-dependency binary heap and priority queue — TypeScript-first npm equivalent of Python heapq, Java PriorityQueue, and Go container/heap.",
  "keywords": [
    "heap",
    "min-heap",
    "max-heap",
    "priority-queue",
    "binary-heap",
    "heapq",
    "data-structure",
    "typescript"
  ],
  "homepage": "https://github.com/trananhtung/heapkit#readme",
  "bugs": { "url": "https://github.com/trananhtung/heapkit/issues" },
  "repository": { "type": "git", "url": "git+https://github.com/trananhtung/heapkit.git" },
  "license": "MIT",
  "author": "trananhtung",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5"
  }
}
